# Copy this file to .env and fill in your values
# cp .env.example .env

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Model to use across all levels (gpt-4o-mini = fast & cheap, gpt-4o = smarter)
OPENAI_MODEL=gpt-4o-mini

# ── Embeddings (F1: semantic memory / RAG) ────────────────────────────────────
# How L5 turns analysis summaries into vectors for semantic recall:
#   local  (default) — deterministic offline hash embedding (32-d), no network
#   openai           — real semantic embeddings (text-embedding-3-small, 1536-d)
VIGIL_EMBED_MODE=local
VIGIL_EMBED_MODEL=text-embedding-3-small

# ── Multi-provider / local models (F3) ────────────────────────────────────────
# Run levels against a local Ollama model or any OpenAI-compatible endpoint.
# Ollama exposes an OpenAI-compatible API at /v1 — no extra SDK needed.
#   1. Install Ollama, then:  ollama pull llama3.1:8b
#   2. Set the provider in an E4 policy or the /inference/compare request.
OLLAMA_BASE_URL=http://localhost:11434/v1
VIGIL_LOCAL_MODEL=llama3.1:8b
# Optional: a third, custom OpenAI-compatible endpoint (vLLM, LM Studio, etc.)
# OPENAI_COMPATIBLE_BASE_URL=http://localhost:8000/v1
# VIGIL_COMPATIBLE_MODEL=gpt-4o-mini

# ── Context-window management (F5) ────────────────────────────────────────────
# Hard token budget for the memory L5 injects into the agent's prompt. When prior
# history would exceed this, older entries are summarized (not silently dropped).
# Install the `tokens` extra for exact counts: pip install -e ".[tokens]"
VIGIL_MEMORY_TOKEN_BUDGET=1500
VIGIL_MEMORY_RECENT_VERBATIM=2

